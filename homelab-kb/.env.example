# Required: generate a long random string for JWT signing
# Example: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string

# Paths on the host machine where PostgreSQL and app data will be persisted
# These should point to your UNRAID NAS mount or local paths
DB_PATH=/mnt/your/unraid/path/kb_db
DATA_PATH=/mnt/your/unraid/path/kb_data
